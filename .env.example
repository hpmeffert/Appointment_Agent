APPOINTMENT_AGENT_APP_HOST=0.0.0.0
APPOINTMENT_AGENT_APP_PORT=8080
APPOINTMENT_AGENT_LOG_LEVEL=info
APPOINTMENT_AGENT_DB_URL=sqlite:////app/data/appointment_agent.db
APPOINTMENT_AGENT_SAFE_DIAGNOSTICS=true
APPOINTMENT_AGENT_BOOKING_WINDOW_DAYS=30
APPOINTMENT_AGENT_MAX_SLOTS_PER_OFFER=3
APPOINTMENT_AGENT_DEFAULT_DURATION_MINUTES=30
APPOINTMENT_AGENT_SLOT_HOLD_MINUTES=10
APPOINTMENT_AGENT_RESCHEDULE_CUTOFF_HOURS=24
APPOINTMENT_AGENT_QUIET_HOURS=21:00-08:00
APPOINTMENT_AGENT_DEFAULT_LANGUAGE=en
APPOINTMENT_AGENT_ASK_CONFIRMATION_BEFORE_COMMIT=true
APPOINTMENT_AGENT_HUMAN_HANDOFF_ENABLED=true
APPOINTMENT_AGENT_IDEMPOTENCY_ENABLED=true
APPOINTMENT_AGENT_GOOGLE_MOCK_MODE=true
APPOINTMENT_AGENT_LEKAB_MOCK_MODE=true
APPOINTMENT_AGENT_DEMO_BASE_PATH=/ui/demo-monitoring/v1.1.0-patch6

# Google OAuth local preparation for v1.1.0 and v1.1.0-patch1 test mode
# Keep mock mode true until you have placed local credentials and retrieved a refresh token.
GOOGLE_REAL_INTEGRATION_ENABLED=false
GOOGLE_TEST_MODE_DEFAULT=simulation
GOOGLE_CONTACTS_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=
GOOGLE_DEFAULT_TIMEZONE=Europe/Berlin
